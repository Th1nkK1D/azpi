{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "warn"
  },
  "rules": {
    "no-debugger": "error",
    "no-console": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["dist/", "node_modules/", "*.js"]
}
